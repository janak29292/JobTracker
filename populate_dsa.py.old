        code_example="""def kadane_with_subarray(arr):
    # Initialize variables to store the maximum sum of the current subarray (max_current)
    # and the global maximum sum found so far (max_global).
    max_current = arr[0]
    max_global = arr[0]

    # Initialize variables to track the start and end indices of the maximum subarray.
    start = 0
    end = 0
    s = 0  # Temporary start index for the current subarray

    # Iterate through the array starting from the second element
    for i in range(1, len(arr)):
        # Check if starting a new subarray with the current element is better than
        # continuing with the existing subarray.
        if arr[i] > max_current + arr[i]:
            max_current = arr[i]
            s = i  # Update the temporary start index to the current index
        else:
            max_current += arr[i]  # Continue the current subarray

        # If the current subarray has a greater sum than the global maximum found so far,
        # update the global maximum and set the start and end indices.
        if max_current > max_global:
            max_global = max_current
            start = s  # Update the start index of the maximum subarray
            end = i  # Update the end index of the maximum subarray
        
        
#         print(f"arr[i]: {arr[i]}, max_current: {max_current}, s: {s}, start: {start}, end: {end}, max_global: {max_global}")

    # Return the maximum sum and the subarray that produces this sum.
    return max_global, arr[start:end+1]

# Example usage
arr = [-2, 1, -3, 4, -1, 2, 1, -5, 4]
# arr = [8, -5, 6, -2, -5, -4]  # Another test case

# Call the function and store the results
max_sum, subarray = kadane_with_subarray(arr)

# Output the results
print("Maximum Sum:", max_sum)
print("Subarray:", subarray)
