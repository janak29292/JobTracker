        space_complexity="""""",
        code_example="""def pivoted_search(arr, key):
    low, high = 0, len(arr) - 1

    while low <= high:
        mid = low + (high - low) // 2

        # Case 1: Find key
        if arr[mid] == key:
            return mid

        # Case 2: Left half is sorted
        if arr[mid] >= arr[low]:
            if key >= arr[low] and key < arr[mid]:
                high = mid - 1
            else:
                low = mid + 1

        # Case 3: Right half is sorted
        else:
            if key > arr[mid] and key <= arr[high]:
                low = mid + 1
            else:
                high = mid - 1
#         print(f"mid: {arr[mid]}")

    return -1  # Key not found

