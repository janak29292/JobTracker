        space_complexity="""""",
        code_example="""def max_product_subarray(arr):
    # Initialize the maximum and minimum product to the first element
    max_product = arr[0]
    min_product = arr[0]
    result = arr[0]
    
    # Variables to track the start and end indices of the max product subarray
    start = 0
    end = 0
    temp_start_min = 0
    temp_start_max = 0

    # Iterate over the array starting from the second element
    for i in range(1, len(arr)):
        # If the current element is negative, swap max_product and min_product
        if arr[i] < 0:
            max_product, min_product = min_product, max_product
            temp_start_min, temp_start_max = temp_start_max, temp_start_min

        # Update max_product and min_product
        if arr[i] > max_product * arr[i]:
            max_product = arr[i]
            temp_start_max = i  # Reset temp_start because we're starting a new subarray
        else:
            max_product *= arr[i]
            
        if arr[i] < min_product * arr[i]:
            min_product = arr[i]
            temp_start_min = i  # Reset temp_start because we're starting a new subarray
        else:
            min_product *= arr[i]

#         max_product = max(arr[i], max_product * arr[i])
#         min_product = min(arr[i], min_product * arr[i])

        # Update the result with the maximum product found so far
        if max_product > result:
            result = max_product
            start = temp_start_max  # Update the start index of the best subarray found
            end = i  # Update the end index of the best subarray found
        
#         print(f"max_product: {max_product}, min_product: {min_product}, result: {result}, temp_start_min: {temp_start_min}, temp_start_max: {temp_start_max}, i: {i}, end: {end}, arr[i]: {arr[i]}")
#         print(f"current_min: {arr[temp_start_min: i+1]}, current_max: {arr[temp_start_max: i + 1]}")

    # Return the result and the subarray
    return result, arr[start:end+1]
#     return result, []

# Example usage
